{
  "name": "@epode/cambia-runtime",
  "version": "0.1.2",
  "description": "Personalize your app UI for each user, automatically and on-device. No tracking. The Cambia adaptive interface engine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && node --test \"dist/**/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@epode/cambia-core": "0.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "typescript": "^5"
  },
  "keywords": [
    "adaptive ui",
    "personalization",
    "ui personalization",
    "per-user",
    "on-device",
    "privacy",
    "no tracking",
    "design system",
    "user preferences"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
