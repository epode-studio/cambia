{
  "name": "@epode/cambia-react",
  "version": "0.1.2",
  "description": "React hook to personalize your UI for each user — adaptive interfaces, on-device, no tracking. useCambia().",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@epode/cambia-runtime": "0.1.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5"
  },
  "keywords": [
    "react",
    "react hook",
    "adaptive ui",
    "personalization",
    "ui personalization",
    "usecambia",
    "per-user",
    "design system",
    "hooks"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
