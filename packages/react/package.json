{
  "name": "@epode/cambia-react",
  "version": "0.1.1",
  "description": "React binding for the Cambia runtime — the useCambia hook for born-adapted, self-personalizing UI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@epode/cambia-runtime": "0.1.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5"
  },
  "keywords": [
    "cambia",
    "react",
    "adaptive-ui",
    "hooks"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
