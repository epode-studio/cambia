{
  "name": "@epode/cambia-core",
  "version": "0.1.2",
  "description": "Read and validate adaptive design-system settings in a DESIGN.md. Core library for Cambia — per-user UI personalization.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && node --test \"dist/**/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.27",
    "typescript": "^5"
  },
  "keywords": [
    "adaptive ui",
    "personalization",
    "design system",
    "design.md",
    "design tokens",
    "tailwind",
    "validation"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
